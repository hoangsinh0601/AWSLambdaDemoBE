{
  "name": "restaurant-serverless-api",
  "version": "1.0.0",
  "description": "Restaurant serverless API for F&B ordering system",
  "main": "src/functions/order/create.ts",
  "scripts": {
    "dev": "serverless offline --config serverless.ts",
    "deploy": "serverless deploy --config serverless.ts",
    "remove": "serverless remove --config serverless.ts",
    "package": "serverless package --config serverless.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "aws",
    "serverless",
    "lambda"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.916.0",
    "@aws-sdk/client-s3": "^3.916.0",
    "@aws-sdk/client-ses": "^3.916.0",
    "@aws-sdk/client-sns": "^3.916.0",
    "@aws-sdk/client-sqs": "^3.916.0",
    "@aws-sdk/lib-dynamodb": "^3.1009.0",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "esbuild": "^0.25.10",
    "serverless": "^3.40.0",
    "serverless-esbuild": "^1.55.1",
    "serverless-offline": "^13.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
